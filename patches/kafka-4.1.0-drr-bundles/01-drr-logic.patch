+
+        public static HandlingOrderPolicy forName(String value) {
+            if (value == null) {
+                return DEFAULT;
+            }
+            // Keep parsing semantics aligned with the broker config validator.
+            String normalizedValue = value.trim();
+            switch (normalizedValue) {
+                case "default":
+                    return DEFAULT;
+                case "shuffle":
+                    return SHUFFLE;
+                case "drr":
+                    return DRR;
+                default:
+                    throw new IllegalArgumentException("Unknown selector handling order policy " + value);
+            }
+        }
+    }
