+    private void replenishDrrDeficitIfNeeded(String connectionId) {
+        Long lastUpdatedPoll = drrPollEpochs.get(connectionId);
+        if (!shouldReplenishForPoll(drrPollId, lastUpdatedPoll)) {
+            return;
+        }
+
+        // Replenish lazily for channels that actually participate in this poll.
+        long currentDeficit = drrDeficits.getOrDefault(connectionId, 0L);
+        drrDeficits.put(connectionId, replenishDeficit(drrConfig, currentDeficit));
+        drrPollEpochs.put(connectionId, drrPollId);
+    }
+
+    private void consumeDrrBudget(KafkaChannel channel, long bytesRead) {
+        if (!isDrrEnabled()) {
+            return;
+        }
+        long cost = drrCost(drrConfig, bytesRead);
+        if (cost <= 0) {
+            return;
+        }
+        long currentDeficit = drrDeficits.getOrDefault(channel.id(), 0L);
+        drrDeficits.put(channel.id(), chargeDeficit(drrConfig, currentDeficit, bytesRead));
+    }
